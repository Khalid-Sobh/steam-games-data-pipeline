  create or replace view `steam-dashboard-project`.`steam_warehouse_steam_warehouse`.`stg_steam_games`
  OPTIONS()
  as -- Staging view: light cleaning on top of raw_games.
-- Materialized as a view — no data duplication, always fresh.



select
    app_id,
    name                                        as game_name,
    release_date,
    release_year,
    price,
    price_tier,
    metacritic_score,
    peak_ccu,
    dlc_count,
    owners_lower,
    windows,
    mac,
    linux,
    genres,
    developers,
    publishers

from `steam-dashboard-project`.`steam_warehouse`.`raw_games`

where
    -- Drop records with no name (junk rows)
    name is not null
    and name != ''
    -- Only keep games with a valid release year
    and release_year is not null
    -- and release_year between 2000 and 2024
    and release_year is not null
    and release_year >= 1970;


