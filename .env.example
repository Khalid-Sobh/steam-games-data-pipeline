# ============================================================
# Steam Pipeline — Environment Variables
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value below
# 3. Never commit .env to git (it is in .gitignore)
# ============================================================

# --- GCP ---
# Your GCP project ID (find it in GCP Console > Project Info)
GCP_PROJECT_ID=my-gcp-project-id

# A globally unique bucket name (lowercase, hyphens only)
GCS_BUCKET=my-steam-pipeline-bucket

# BigQuery dataset name (no spaces)
BQ_DATASET=steam_warehouse

# GCP region for Dataproc Serverless (single-region, e.g. us-central1)
GCP_REGION=us-central1

# GCS/BigQuery location (multi-region, e.g. US or EU)
GCP_LOCATION=US

# --- Kaggle ---
# Get these from: https://www.kaggle.com/settings > API > Create New Token
KAGGLE_USERNAME=my_kaggle_username
KAGGLE_KEY=my_kaggle_api_key_here

# Absolute path to the project root on the HOST machine
# On Codespaces: /workspaces/your-repo-name
# On local Linux/Mac: /home/youruser/steam-pipeline
HOST_WORKDIR=/workspaces/steam-dashboard

# --- Airflow ---
# Run this to generate a Fernet key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your_generated_fernet_key_here

# Airflow user ID (run: echo $UID on Linux/Mac, use 50000 on Windows)
AIRFLOW_UID=50000

# Airflow web UI credentials
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
